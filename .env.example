# Variables básicas de Postgres
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password_change_me
POSTGRES_PORT=5432

# pgAdmin (solo se usa en desarrollo u ocasión puntual en producción bajo control)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=supersecret_change_me

# Timezone para backups y contenedores
TZ=UTC

# Configuración de Backups
# Formato cron: min hora dia-mes mes dia-semana (ej: 0 2 * * * -> cada día a las 02:00)
BACKUP_CRON_SCHEDULE=0 2 * * *
# Días que se conservarán los archivos (se eliminarán los más antiguos)
BACKUP_RETENTION_DAYS=7

# Nota: copie este archivo a .env y cambie las credenciales para producción.
