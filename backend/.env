# Entorno desarrollo (local, con DB en Docker)
NODE_ENV=development

# DB (expuesta por Docker en localhost)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app_db
TYPEORM_LOGGING=true

# JWT
JWT_SECRET=dev_jwt_secret_change
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_refresh_secret_change
JWT_REFRESH_EXPIRES_IN=7d

# Email / SMTP (Mailhog en desarrollo) - Se puede comentar si no se usa
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Registro Estudiantes Dev <no-reply@local.test>"
EMAIL_DEV_PREVIEW=true

# Redis (colas Bull) - Se puede comentar si no se usa
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=20
THROTTLE_LOGIN_LIMIT=5
THROTTLE_LOGIN_TTL=60
THROTTLE_FORGOT_LIMIT=3
THROTTLE_FORGOT_TTL=300

# Seeds
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=AdminPassword123!

# App
PORT=3000

# Timezone
TZ=UTC
