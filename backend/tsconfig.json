{
  "compilerOptions": {
    "target": "ES2020",
  "module": "commonjs",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "./src",
    "paths": {
      "@entities/*": ["entities/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
