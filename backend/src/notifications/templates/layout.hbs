<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{subject}}</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f5f7fa; margin:0; padding:0; }
    .container { max-width:600px; margin:0 auto; background:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.06); }
    .header { background:#0d3b66; color:#ffffff; padding:20px; text-align:center; }
    .header img { max-height:50px; }
    .content { padding:30px 25px; color:#333333; line-height:1.5; }
    h1 { font-size:22px; margin-top:0; color:#0d3b66; }
    .btn { display:inline-block; background:#1d72b8; color:#ffffff !important; padding:12px 22px; border-radius:4px; text-decoration:none; font-weight:600; }
    .btn:hover { background:#155d90; }
    .footer { font-size:12px; color:#999; text-align:center; padding:15px 10px 25px; }
    .badge { background:#0d3b66; color:#fff; padding:4px 10px; border-radius:12px; font-size:12px; }
    @media (max-width:600px){ .content { padding:20px 18px; } h1 { font-size:20px; } }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div style="font-size:20px;font-weight:700;">Universidad Mariano Gálvez</div>
      <div style="margin-top:4px;font-size:13px;opacity:.85;">Plataforma de Registro de Estudiantes</div>
    </div>
    <div class="content">
      {{{body}}}
    </div>
    <div class="footer">
      © {{year}} UMG - Este mensaje fue enviado automáticamente. No respondas a este correo.
    </div>
  </div>
</body>
</html>