# Variables de conexión a la base de datos
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=app_password_change_me
DB_NAME=app_db

# Logging de TypeORM (true/false)
TYPEORM_LOGGING=true

# Usuario seed admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=AdminPassword123!

# Pepper opcional (para hashing adicional fuera de bcrypt) - dejar vacío si no se usa
PASSWORD_PEPPER=

# JWT
JWT_SECRET=changeme_jwt_secret_super_seguro
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Tokens de verificación / reset (tiempo recomendado menor a 1h)
VERIFICATION_TOKEN_EXPIRES_HOURS=24
RESET_PASSWORD_TOKEN_EXPIRES_HOURS=1

# Email SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@example.com
SMTP_PASSWORD=changeme_smtp_pass
EMAIL_FROM="Registro Estudiantes <no-reply@example.com>"

# Redis / Bull (cola de emails)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Modo preview de emails (true = no se envían, se guardan en EmailLog con html)
EMAIL_DEV_PREVIEW=false

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=20
THROTTLE_LOGIN_LIMIT=5
THROTTLE_LOGIN_TTL=60
THROTTLE_FORGOT_LIMIT=3
THROTTLE_FORGOT_TTL=300

# App
PORT=3000
